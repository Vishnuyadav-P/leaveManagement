# MongoDB Atlas Connection String
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname
# Get this from: https://cloud.mongodb.com → Cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://vishnu:S1rAGgNw3QpASrh2@leavemgmt.0qy3dwq.mongodb.net/?appName=leavemgmt

# JWT Secret for signing tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: Use a long, random string (minimum 32 characters)
JWT_SECRET=your_super_secret_jwt_key_here_minimum_32_characters

# Frontend API Base URL
# For local development: /api
# For production with separate backend: https://your-backend-url.com/api
VITE_API_BASE_URL=/api
