# MongoDB Atlas Connection String
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname
# Get this from: https://cloud.mongodb.com → Cluster → Connect → Drivers
MONGODB_URI=""

# JWT Secret for signing tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: Use a long, random string (minimum 32 characters)
JWT_SECRET=""

# Frontend API Base URL
# For local development: /api
# For production with separate backend: https://your-backend-url.com/api
VITE_API_BASE_URL=/api
